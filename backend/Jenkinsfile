// Project 4 - Backend CI/CD Pipeline (GitOps via Argo CD)
//
// Flow: Checkout -> Maven Build -> Unit Test -> SonarQube -> Quality Gate
//       -> Parallel Stage -> Package Jar -> OWASP Dependency Check
//       -> Docker Build -> Trivy Scan -> Docker Scout (optional)
//       -> Push Image -> Update GitOps Values -> Wait for Argo CD Sync
//
// Key change from project-03: this pipeline no longer touches the cluster
// at all - no `kubectl`, no `helm upgrade`, no AWS credentials. It ends by
// committing a new image tag to Git; Argo CD (watching the repo) does the
// actual deploy. See gitops/README.md for the full picture.
//
// Wired to this deployment's actual infrastructure:
//   - Docker Hub:    docker.io/devopstraining064
//   - Argo CD server: set ARGOCD_SERVER below to the LoadBalancer hostname
//     printed by `kubectl get svc argocd-server -n argocd` after running
//     scripts/argocd-install.sh (a one-time value - it doesn't change
//     unless the Service is recreated).

pipeline {
    agent any

    tools {
        jdk 'java21'
        maven 'maven3.9.16'
    }

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        disableConcurrentBuilds()
        timeout(time: 50, unit: 'MINUTES')
    }

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')
        ARGOCD_AUTH_TOKEN     = credentials('argocd-auth-token')

        SONARQUBE_ENV    = 'sonarqube-server'
        // TODO: replace with the real argocd-server LoadBalancer hostname
        // (see header comment above) - a placeholder can't be discovered
        // automatically since Jenkins has no kubectl access to look it up.
        ARGOCD_SERVER    = '<argocd-lb-hostname>'
        GIT_BRANCH_NAME  = 'project-04-gitops-argocd'

        BACKEND_IMAGE = 'devopstraining064/enterprise-devops-backend'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Maven Build') {
            steps {
                dir('backend') {
                    script {
                        // IMAGE_TAG is this pipeline's own pom.xml version plus its own
                        // build number, e.g. 1.0.0-17 - same technique as project-03,
                        // still meaningful here since backend/frontend are still two
                        // independently-versioned Jenkins jobs.
                        def devVersion = sh(
                            script: "mvn -B -ntp -q -DforceStdout help:evaluate -Dexpression=project.version",
                            returnStdout: true
                        ).trim()
                        env.IMAGE_TAG = "${devVersion.replace('-SNAPSHOT', '')}-${env.BUILD_NUMBER}"
                    }
                    sh 'mvn -B -ntp clean compile'
                }
            }
        }

        stage('Unit Test') {
            steps {
                dir('backend') {
                    sh 'mvn -B -ntp test'
                }
            }
            post {
                always {
                    junit testResults: 'backend/target/surefire-reports/*.xml', allowEmptyResults: false
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('backend') {
                    withSonarQubeEnv("${SONARQUBE_ENV}") {
                        sh 'mvn -B -ntp sonar:sonar'
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Parallel Stage') {
            parallel {
                stage('Publish Coverage Report') {
                    steps {
                        dir('backend') {
                            recordCoverage tools: [[parser: 'JACOCO', pattern: 'target/site/jacoco/jacoco.xml']]
                        }
                    }
                }
                stage('Dependency Tree Audit') {
                    steps {
                        dir('backend') {
                            sh 'mvn -B -ntp dependency:tree -DoutputFile=target/dependency-tree.txt'
                        }
                    }
                }
            }
        }

        stage('Package Jar') {
            steps {
                dir('backend') {
                    sh 'mvn -B -ntp package -DskipTests'
                }
            }
            post {
                success {
                    archiveArtifacts artifacts: 'backend/target/enterprise-devops-backend.jar', fingerprint: true
                }
            }
        }

        stage('OWASP Dependency Check') {
            steps {
                dir('backend') {
                    // Fails the build on any dependency with CVSS >= 8
                    // (see failBuildOnCVSS in pom.xml). Suppress confirmed
                    // false positives in owasp-suppressions.xml, never here.
                    sh 'mvn -B -ntp dependency-check:check'
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'backend/target/dependency-check-report.*', allowEmptyArchive: true
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh """
                    docker build -f docker/backend-ci.Dockerfile \
                        -t ${BACKEND_IMAGE}:${IMAGE_TAG} -t ${BACKEND_IMAGE}:latest .
                """
            }
        }

        stage('Trivy Scan') {
            steps {
                // Fails the build on any CRITICAL vulnerability with a known
                // fix available. Unfixed CVEs are reported but don't block -
                // there's nothing actionable to do about them yet.
                sh """
                    trivy image --severity CRITICAL --exit-code 1 --ignore-unfixed \
                        ${BACKEND_IMAGE}:${IMAGE_TAG}
                """
            }
        }

        stage('Docker Scout (optional)') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    sh "docker scout cves ${BACKEND_IMAGE}:${IMAGE_TAG} --only-severity critical --exit-code"
                }
            }
        }

        stage('Push Image') {
            steps {
                sh '''
                    echo "$DOCKERHUB_CREDENTIALS_PSW" | docker login -u "$DOCKERHUB_CREDENTIALS_USR" --password-stdin
                '''
                sh "docker push ${BACKEND_IMAGE}:${IMAGE_TAG}"
                sh "docker push ${BACKEND_IMAGE}:latest"
                sh 'docker logout'
            }
        }

        stage('Update GitOps Values') {
            steps {
                sh "./scripts/update-image-tag.sh backend ${IMAGE_TAG}"
            }
        }

        stage('Wait for Argo CD Sync') {
            steps {
                sh """
                    argocd login ${ARGOCD_SERVER} --auth-token \$ARGOCD_AUTH_TOKEN --insecure --grpc-web
                    argocd app wait enterprise-app --health --sync --timeout 300
                """
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "Committed backend image tag ${IMAGE_TAG} - Argo CD synced it to the cluster."
        }
        failure {
            echo 'Backend pipeline failed - see docs/06-Troubleshooting.md for common causes.'
        }
    }
}
