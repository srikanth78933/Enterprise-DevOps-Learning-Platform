<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
    Add suppressions here only for confirmed false positives or accepted-risk
    findings, each with a reason and a link to the CVE/discussion. Never
    suppress a real vulnerability just to make the build pass - that's what
    failBuildOnCVSS in pom.xml is there to prevent.

    Example:
    <suppress>
        <notes>False positive: this CVE affects the C++ implementation, not
        the Java binding we use. See https://github.com/.../issues/123</notes>
        <packageUrl regex="true">^pkg:maven/com\.example/library@.*$</packageUrl>
        <cve>CVE-2023-00000</cve>
    </suppress>
    -->
</suppressions>
