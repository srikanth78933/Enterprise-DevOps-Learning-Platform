// Project 3 - Frontend CI/CD Pipeline (independent of backend/Jenkinsfile)
//
// Flow: Checkout -> Install & Test -> Build -> Docker Build -> Push Image
//       -> Package & Push Helm Chart -> Helm Upgrade (frontend only) -> Verify
//
// This pipeline only ever touches the `frontend` values of the
// enterprise-app Helm release (--reuse-values), so it can run and deploy
// completely independently of backend/Jenkinsfile.
//
// The chart itself is packaged and pushed to Docker Hub as an OCI artifact
// before every deploy, purely for a versioned, auditable record of what was
// deployed - see the matching comment in backend/Jenkinsfile for the full
// reasoning (same tradeoff, same pattern, both pipelines push independently).
//
// Wired to this deployment's actual infrastructure:
//   - Docker Hub:   docker.io/devopstraining064
//   - EKS cluster:  eks-cluster (eu-west-3)

pipeline {
    agent any

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        disableConcurrentBuilds()
        timeout(time: 30, unit: 'MINUTES')
    }

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')
        AWS_ACCESS_KEY_ID     = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')

        AWS_REGION       = 'eu-west-3'
        EKS_CLUSTER_NAME = 'eks-cluster'
        K8S_NAMESPACE    = 'enterprise-devops'
        HELM_RELEASE     = 'enterprise-app'

        FRONTEND_IMAGE = 'devopstraining064/enterprise-devops-frontend'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install & Test') {
            steps {
                dir('frontend') {
                    sh 'npm ci'
                    sh 'CI=true npm test'
                    script {
                        // IMAGE_TAG is this pipeline's own package.json version plus
                        // its own build number, e.g. 1.0.0-9 - independent of whatever
                        // tag backend/Jenkinsfile last produced, since these two
                        // pipelines now run and version themselves completely separately.
                        def pkgVersion = sh(
                            script: "node -p \"require('./package.json').version\"",
                            returnStdout: true
                        ).trim()
                        env.IMAGE_TAG = "${pkgVersion}-${env.BUILD_NUMBER}"
                    }
                }
            }
        }

        stage('Build') {
            steps {
                dir('frontend') {
                    // Relative path, not an absolute hostname: React inlines this at
                    // build time (it can't be changed at runtime), and the Ingress
                    // already serves both frontend and backend on the same host, so
                    // a relative baseURL resolves correctly no matter what hostname
                    // the browser actually used, and never needs CORS at all (same
                    // origin). An absolute URL here would only ever work for the one
                    // hostname it was built with.
                    sh 'CI=true REACT_APP_API_BASE_URL=/api npm run build'
                }
            }
            post {
                success {
                    archiveArtifacts artifacts: 'frontend/build/**', fingerprint: false
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh """
                    docker build -f docker/frontend-ci.Dockerfile \
                        -t ${FRONTEND_IMAGE}:${IMAGE_TAG} -t ${FRONTEND_IMAGE}:latest .
                """
            }
        }

        stage('Push Image') {
            steps {
                sh '''
                    echo "$DOCKERHUB_CREDENTIALS_PSW" | docker login -u "$DOCKERHUB_CREDENTIALS_USR" --password-stdin
                '''
                sh "docker push ${FRONTEND_IMAGE}:${IMAGE_TAG}"
                sh "docker push ${FRONTEND_IMAGE}:latest"
                sh 'docker logout'
            }
        }

        stage('Package & Push Helm Chart') {
            steps {
                script {
                    // Chart version follows the same "<base>-<build>" pattern as
                    // the image tag - Chart.yaml's own version is the floating
                    // dev baseline, this stamps a unique one per build.
                    env.CHART_VERSION = "1.0.0-${env.BUILD_NUMBER}"
                }
                sh "helm package helm/enterprise-app --version ${CHART_VERSION} --app-version ${IMAGE_TAG} --destination ."
                sh '''
                    echo "$DOCKERHUB_CREDENTIALS_PSW" | helm registry login registry-1.docker.io -u "$DOCKERHUB_CREDENTIALS_USR" --password-stdin
                '''
                sh "helm push enterprise-app-${CHART_VERSION}.tgz oci://registry-1.docker.io/devopstraining064"
                sh "rm -f enterprise-app-${CHART_VERSION}.tgz"
                sh 'helm registry logout registry-1.docker.io'
            }
        }

        stage('Helm Upgrade') {
            steps {
                sh """
                    aws eks update-kubeconfig --name ${EKS_CLUSTER_NAME} --region ${AWS_REGION}

                    helm upgrade --install ${HELM_RELEASE} helm/enterprise-app \
                        -n ${K8S_NAMESPACE} --create-namespace \
                        --reuse-values \
                        --set frontend.image.tag=${IMAGE_TAG}
                """
            }
        }

        stage('Verify') {
            steps {
                sh "kubectl rollout status deployment/frontend -n ${K8S_NAMESPACE} --timeout=180s"
                sh './scripts/verify-frontend.sh'
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "Deployed ${FRONTEND_IMAGE}:${IMAGE_TAG} via Helm release ${HELM_RELEASE}"
        }
        failure {
            echo 'Frontend pipeline failed - see docs/06-Troubleshooting.md for common causes.'
        }
    }
}
