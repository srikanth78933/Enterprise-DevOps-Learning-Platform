// Project 3 - Frontend CI/CD Pipeline (independent of backend/Jenkinsfile)
//
// Flow: Checkout -> Install & Test -> Build -> Docker Build -> Push Image
//       -> Helm Upgrade (frontend only) -> Verify
//
// This pipeline only ever touches the `frontend` values of the
// enterprise-app Helm release (--reuse-values), so it can run and deploy
// completely independently of backend/Jenkinsfile.

pipeline {
    agent any

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        disableConcurrentBuilds()
        timeout(time: 30, unit: 'MINUTES')
    }

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')
        AWS_ACCESS_KEY_ID     = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')

        AWS_REGION       = 'us-east-1'
        EKS_CLUSTER_NAME = 'enterprise-devops-dev-eks'
        K8S_NAMESPACE    = 'enterprise-devops'
        HELM_RELEASE     = 'enterprise-app'

        FRONTEND_IMAGE = 'yourdockerhubuser/enterprise-devops-frontend'
        IMAGE_TAG      = "${env.BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install & Test') {
            steps {
                dir('frontend') {
                    sh 'npm ci'
                    sh 'CI=true npm test'
                }
            }
        }

        stage('Build') {
            steps {
                dir('frontend') {
                    sh 'CI=true npm run build'
                }
            }
            post {
                success {
                    archiveArtifacts artifacts: 'frontend/build/**', fingerprint: false
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh """
                    docker build -f docker/frontend-ci.Dockerfile \
                        -t ${FRONTEND_IMAGE}:${IMAGE_TAG} -t ${FRONTEND_IMAGE}:latest .
                """
            }
        }

        stage('Push Image') {
            steps {
                sh '''
                    echo "$DOCKERHUB_CREDENTIALS_PSW" | docker login -u "$DOCKERHUB_CREDENTIALS_USR" --password-stdin
                '''
                sh "docker push ${FRONTEND_IMAGE}:${IMAGE_TAG}"
                sh "docker push ${FRONTEND_IMAGE}:latest"
                sh 'docker logout'
            }
        }

        stage('Helm Upgrade') {
            steps {
                sh """
                    aws eks update-kubeconfig --name ${EKS_CLUSTER_NAME} --region ${AWS_REGION}

                    helm upgrade --install ${HELM_RELEASE} helm/enterprise-app \
                        -n ${K8S_NAMESPACE} --create-namespace \
                        --reuse-values \
                        --set frontend.image.tag=${IMAGE_TAG} \
                        --wait --timeout 5m
                """
            }
        }

        stage('Verify') {
            steps {
                sh "kubectl rollout status deployment/frontend -n ${K8S_NAMESPACE} --timeout=180s"
                sh './scripts/verify-frontend.sh'
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "Deployed ${FRONTEND_IMAGE}:${IMAGE_TAG} via Helm release ${HELM_RELEASE}"
        }
        failure {
            echo 'Frontend pipeline failed - see docs/06-Troubleshooting.md for common causes.'
        }
    }
}
