// Project 4 - Frontend CI/CD Pipeline (GitOps via Argo CD)
//
// Flow: Checkout -> Install & Test -> npm audit -> Build -> Docker Build
//       -> Trivy Scan -> Docker Scout (optional) -> Push Image
//       -> Update GitOps Values -> Wait for Argo CD Sync
//
// Same key change as backend/Jenkinsfile: no cluster access, no AWS
// credentials, no `helm upgrade` - ends at a Git commit that Argo CD
// picks up. See gitops/README.md.
//
// Wired to this deployment's actual infrastructure:
//   - Docker Hub:    docker.io/devopstraining064
//   - Argo CD server: set ARGOCD_SERVER below to the LoadBalancer hostname
//     printed by `kubectl get svc argocd-server -n argocd` after running
//     scripts/argocd-install.sh (a one-time value - it doesn't change
//     unless the Service is recreated).

pipeline {
    agent any

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        disableConcurrentBuilds()
        timeout(time: 30, unit: 'MINUTES')
    }

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')
        ARGOCD_AUTH_TOKEN     = credentials('argocd-auth-token')

        // TODO: replace with the real argocd-server LoadBalancer hostname
        // (see header comment above) - a placeholder can't be discovered
        // automatically since Jenkins has no kubectl access to look it up.
        ARGOCD_SERVER   = '<argocd-lb-hostname>'
        GIT_BRANCH_NAME = 'project-04-gitops-argocd'

        FRONTEND_IMAGE = 'devopstraining064/enterprise-devops-frontend'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install & Test') {
            steps {
                dir('frontend') {
                    sh 'npm ci'
                    sh 'CI=true npm test'
                    script {
                        // IMAGE_TAG is this pipeline's own package.json version plus
                        // its own build number, e.g. 1.0.0-9 - same technique as
                        // project-03.
                        def pkgVersion = sh(
                            script: "node -p \"require('./package.json').version\"",
                            returnStdout: true
                        ).trim()
                        env.IMAGE_TAG = "${pkgVersion}-${env.BUILD_NUMBER}"
                    }
                }
            }
        }

        stage('npm audit') {
            steps {
                dir('frontend') {
                    // OWASP Dependency Check's npm equivalent for this
                    // project - fails on any critical advisory. Threshold
                    // is "critical" rather than "high" deliberately:
                    // react-scripts pulls in webpack-dev-server, which has
                    // long-standing "high" advisories in transitive deps
                    // (sockjs, uuid) that only run in the local dev server
                    // and never ship in the production Docker image built
                    // from frontend/build. Gating on "high" here would fail
                    // every build on noise instead of real production risk.
                    // Run `npm audit fix` locally to resolve real findings,
                    // never `--force` blindly (it can bump majors).
                    sh 'npm audit --omit=dev --audit-level=critical'
                }
            }
        }

        stage('Build') {
            steps {
                dir('frontend') {
                    // Relative path, not an absolute hostname - React inlines this
                    // at build time, and the Ingress serves both frontend and
                    // backend on the same host, so a relative baseURL resolves
                    // correctly no matter what hostname the browser used, and
                    // never needs CORS (same origin). Found as a real bug on
                    // project-03: an absolute/missing value here means every
                    // deployed user's browser tries to reach localhost:8080.
                    sh 'CI=true REACT_APP_API_BASE_URL=/api npm run build'
                }
            }
            post {
                success {
                    archiveArtifacts artifacts: 'frontend/build/**', fingerprint: false
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh """
                    docker build -f docker/frontend-ci.Dockerfile \
                        -t ${FRONTEND_IMAGE}:${IMAGE_TAG} -t ${FRONTEND_IMAGE}:latest .
                """
            }
        }

        stage('Trivy Scan') {
            steps {
                sh """
                    trivy image --severity CRITICAL --exit-code 1 --ignore-unfixed \
                        ${FRONTEND_IMAGE}:${IMAGE_TAG}
                """
            }
        }

        stage('Docker Scout (optional)') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    sh "docker scout cves ${FRONTEND_IMAGE}:${IMAGE_TAG} --only-severity critical --exit-code"
                }
            }
        }

        stage('Push Image') {
            steps {
                sh '''
                    echo "$DOCKERHUB_CREDENTIALS_PSW" | docker login -u "$DOCKERHUB_CREDENTIALS_USR" --password-stdin
                '''
                sh "docker push ${FRONTEND_IMAGE}:${IMAGE_TAG}"
                sh "docker push ${FRONTEND_IMAGE}:latest"
                sh 'docker logout'
            }
        }

        stage('Update GitOps Values') {
            steps {
                sh "./scripts/update-image-tag.sh frontend ${IMAGE_TAG}"
            }
        }

        stage('Wait for Argo CD Sync') {
            steps {
                sh """
                    argocd login ${ARGOCD_SERVER} --auth-token \$ARGOCD_AUTH_TOKEN --insecure --grpc-web
                    argocd app wait enterprise-app --health --sync --timeout 300
                """
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "Committed frontend image tag ${IMAGE_TAG} - Argo CD synced it to the cluster."
        }
        failure {
            echo 'Frontend pipeline failed - see docs/06-Troubleshooting.md for common causes.'
        }
    }
}
