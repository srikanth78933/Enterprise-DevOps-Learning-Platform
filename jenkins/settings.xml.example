<!--
  Template Maven settings.xml for the Jenkins agents running this pipeline.

  DO NOT commit a real settings.xml with live credentials. In Jenkins, upload
  the real version via "Managed files" (Config File Provider plugin) and bind
  it in the pipeline with a `configFileProvider` step, or inject secrets as
  environment variables the way the Jenkinsfile already does for Docker Hub
  (`credentials('dockerhub-credentials')`).

  This file exists so students can see the shape of what's needed:
    - a pluginGroup entry so `mvn sonar:sonar` resolves without a fully
      qualified plugin coordinate
    - an optional mirror if your org runs a Nexus/Artifactory proxy
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">

    <pluginGroups>
        <pluginGroup>org.sonarsource.scanner.maven</pluginGroup>
    </pluginGroups>

    <!-- Uncomment and point at your internal proxy if you have one.
    <mirrors>
        <mirror>
            <id>internal-mirror</id>
            <mirrorOf>central</mirrorOf>
            <url>https://nexus.internal.example.com/repository/maven-public/</url>
        </mirror>
    </mirrors>
    -->

    <!-- Example only - real credentials belong in Jenkins Credentials, never here.
    <servers>
        <server>
            <id>internal-repo</id>
            <username>${env.REPO_USER}</username>
            <password>${env.REPO_PASSWORD}</password>
        </server>
    </servers>
    -->

</settings>
