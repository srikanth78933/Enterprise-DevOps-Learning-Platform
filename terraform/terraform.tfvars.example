# Copy to terraform.tfvars and adjust. terraform.tfvars is gitignored -
# never commit real values (account-specific CIDR overlaps, etc. are fine
# to keep private but not sensitive; this file matters more once you add
# secrets to Terraform in later projects).

project_name = "enterprise-devops"
environment  = "dev"
aws_region   = "us-east-1"

availability_zones   = ["us-east-1a", "us-east-1b"]
vpc_cidr             = "10.20.0.0/16"
public_subnet_cidrs  = ["10.20.0.0/24", "10.20.1.0/24"]
private_subnet_cidrs = ["10.20.10.0/24", "10.20.11.0/24"]

cluster_version      = "1.30"
node_instance_types  = ["t3.medium"]
node_desired_size    = 2
node_min_size        = 2
node_max_size        = 4
